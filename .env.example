APP_NAME=PraxiTests
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=praxitests
DB_USERNAME=root
DB_PASSWORD=

# --- Cache / Queue / Session ---
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@praxitests.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Storage S3 (optionnel) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- IA ---
AI_DEFAULT_DRIVER=anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- PraxiTests ---
PRAXITESTS_LICENSE_KEY=
PRAXITESTS_LICENSE_API=https://license.praxis-accompagnement.fr/api
PRAXITESTS_GAMIFICATION_ENABLED=true
PRAXITESTS_NEUROMARKETING_ENABLED=true
PRAXITESTS_PLUGINS_AUTODISCOVER=true
PRAXITESTS_MULTITENANT=true

# --- Compte admin par défaut (utilisé par AdminUserSeeder, à changer en prod) ---
PRAXITESTS_ADMIN_EMAIL=admin@praxitests.local
PRAXITESTS_ADMIN_PASSWORD=changeme123
PRAXITESTS_ADMIN_NAME="Administrateur"
