APP_NAME=PraxiQuest
APP_ENV=local
APP_KEY=
# SÉCURITÉ : false par défaut. En production il DOIT rester false (sinon Ignition
# expose la stack trace, les variables d'env et les secrets). Passer à true
# uniquement en dev local si besoin.
APP_DEBUG=false
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=praxiquest
DB_USERNAME=root
DB_PASSWORD=

# --- Cache / Queue / Session ---
# QUEUE_CONNECTION=sync  → OVH sans cron : l'IA tourne pendant le clic "Terminer"
#                          (~20-40s d'attente, résultats immédiats à l'arrivée)
# QUEUE_CONNECTION=database → OVH avec cron schedule:run (plus robuste)
# QUEUE_CONNECTION=redis    → Serveur dédié avec Supervisor (production avancée)
BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Sécurité cookies de session. EN PRODUCTION : laisser à true (HTTPS requis).
# En dev local sans HTTPS, passer à false.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
# RAPPEL PROD : APP_ENV=production et APP_DEBUG=false (sinon Ignition expose la stack/secrets).

# Redis (optionnel — décommenter si dispo)
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# --- Mail ---
# Local (Mailpit / Mailtrap)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@praxiquest.local"
MAIL_FROM_NAME="${APP_NAME}"

# OVH MX Plan (décommenter et adapter)
# MAIL_MAILER=smtp
# MAIL_HOST=ssl0.ovh.net
# MAIL_PORT=465
# MAIL_USERNAME=contact@votredomaine.fr
# MAIL_PASSWORD=votremotdepasse
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS="contact@votredomaine.fr"
# MAIL_FROM_NAME="${APP_NAME}"

# Brevo / SendGrid (recommandé en production pour le deliverability)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=votre@email.com
# MAIL_PASSWORD=votre_cle_smtp_brevo
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@votredomaine.fr"
# MAIL_FROM_NAME="${APP_NAME}"

# --- Storage S3 (optionnel) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- IA ---
AI_DEFAULT_DRIVER=anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# -------------------------------------------------
# BILLING — Stripe Cashier (optionnel)
# Clés dashboard.stripe.com/apikeys
# Utiliser pk_test_ / sk_test_ en local et staging,
# pk_live_ / sk_live_ uniquement en production.
# -------------------------------------------------
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
# WEBHOOK STRIPE (cf. audit C-2) — OBLIGATOIRE en production.
# Cashier enregistre automatiquement la route POST /stripe/webhook
# (nommée cashier.webhook) et vérifie la signature HMAC dès que ce secret
# est défini. Étapes côté Stripe Dashboard > Developers > Webhooks :
#   1. Ajouter l'endpoint : https://VOTRE_DOMAINE/stripe/webhook
#   2. Événements à écouter : customer.subscription.created/updated/deleted,
#      invoice.paid, invoice.payment_failed

# -------------------------------------------------
# ADMIN PAR DEFAUT (seed)
# A changer immediatement apres la 1re connexion.
# -------------------------------------------------
PRAXIQUEST_ADMIN_EMAIL=admin@praxiquest.local
PRAXIQUEST_ADMIN_PASSWORD=changeme-immediately
