APP_NAME=PraxiQuest
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=praxiquest
DB_USERNAME=root
DB_PASSWORD=

# --- Cache / Queue / Session ---
# QUEUE_CONNECTION=sync  → OVH sans cron : l'IA tourne pendant le clic "Terminer"
#                          (~20-40s d'attente, résultats immédiats à l'arrivée)
# QUEUE_CONNECTION=database → OVH avec cron schedule:run (plus robuste)
# QUEUE_CONNECTION=redis    → Serveur dédié avec Supervisor (production avancée)
BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (optionnel — décommenter si dispo)
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# --- Mail ---
# Local (Mailpit / Mailtrap)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@praxiquest.local"
MAIL_FROM_NAME="${APP_NAME}"

# OVH MX Plan (décommenter et adapter)
# MAIL_MAILER=smtp
# MAIL_HOST=ssl0.ovh.net
# MAIL_PORT=465
# MAIL_USERNAME=contact@votredomaine.fr
# MAIL_PASSWORD=votremotdepasse
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS="contact@votredomaine.fr"
# MAIL_FROM_NAME="${APP_NAME}"

# Brevo / SendGrid (recommandé en production pour le deliverability)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=votre@email.com
# MAIL_PASSWORD=votre_cle_smtp_brevo
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@votredomaine.fr"
# MAIL_FROM_NAME="${APP_NAME}"

# --- Storage S3 (optionnel) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- IA ---
AI_DEFAULT_DRIVER=anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTH